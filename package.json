{
  "name": "openclaw-security",
  "description": "Security audit platform for OpenClaw Cloud deployments",
  "version": "0.1.0",
  "license": "MIT",
  "homepage": "https://github.com/openclaw/openclaw-security#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw/openclaw-security.git"
  },
  "bugs": {
    "url": "https://github.com/openclaw/openclaw-security/issues"
  },
  "keywords": [
    "security",
    "audit",
    "scanner",
    "openclaw",
    "cloudflare-workers",
    "ai-agents",
    "vulnerability-scanner"
  ],
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "bun test",
    "build": "bun run --filter '*' build",
    "lint": "bunx biome lint .",
    "lint:fix": "bunx biome lint --fix .",
    "format": "bunx biome format --write .",
    "format:check": "bunx biome format .",
    "typecheck": "bunx tsc --noEmit -p packages/scanner-core/tsconfig.json && bunx tsc --noEmit -p packages/cli/tsconfig.json && bunx tsc --noEmit -p apps/web/tsconfig.json && bunx tsc --noEmit -p apps/extension/tsconfig.json",
    "ci": "bun run typecheck && bun run lint && bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0"
  }
}
